{
  "scripts": {
"tailwind:build": "./node_modules/.bin/tailwindcss -i ./style/tailwind.css -o ./public/tailwind.css",
"tailwind:watch": "./node_modules/.bin/tailwindcss -i ./style/tailwind.css -o ./public/tailwind.css --watch",

    "dev": "PORT=$(./scripts/find-port.sh) && bun concurrently \"bun run tailwind:watch\" \"trunk serve --port $PORT\"",
    "build": "bun run tailwind:build && trunk build --release"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "tailwindcss": "^4.3.0"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.3.0"
  }
}

